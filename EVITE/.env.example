# Copy this file to `.env` and fill in real values.
# Vercel injects these directly in production — set them in the dashboard
# instead of committing this file with real values.

# Required — Supabase connection string. Use the TRANSACTION POOLER URL
# (port 6543) from your Supabase project's Database settings page.
# Format: postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Required in production — cookie signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Optional — Google Gemini API key for the /api/ai_input endpoint.
# Without this the AI route returns 503 but everything else works.
GEMINI_API_KEY=

# Event-scout agent (finds public events near users at 5 AM local time).
# Anthropic key powers the web-search discovery; without it the scout falls
# back to Ticketmaster-only. Get one at https://platform.claude.com
ANTHROPIC_API_KEY=

# Optional — Ticketmaster Discovery API key for big structured listings.
# Free tier at https://developer.ticketmaster.com
TICKETMASTER_API_KEY=

# Recommended in production — protects /api/agent/run. Vercel Cron sends it
# automatically as "Authorization: Bearer <value>" when set in the dashboard.
CRON_SECRET=

# Optional — Resend key for emailing invitations (https://resend.com).
# Without it, email invitations are still created but no email is sent.
# Note: the test sender (onboarding@resend.dev) only delivers to the Resend
# account owner's address — verify a domain for real guests.
RESEND_API_KEY=

# Optional — base URL used in invitation email links (defaults to the
# production deployment URL).
# APP_BASE_URL=https://e-vite-vert.vercel.app

# Optional — set to "production" to enable secure cookies. Vercel sets this
# automatically; only set locally if you're testing prod-mode behavior.
# NODE_ENV=production

# Optional — port for `npm start` locally (default 3001). Vercel ignores it.
# PORT=3001
