{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/", "destination": "/frontend/pages/landing-page.html" },
    { "source": "/login", "destination": "/frontend/pages/login.html" },
    { "source": "/signup", "destination": "/frontend/pages/signup.html" },
    { "source": "/tree", "destination": "/frontend/pages/tree.html" },
    { "source": "/profile", "destination": "/frontend/pages/profile.html" },
    { "source": "/create-event", "destination": "/frontend/pages/create-event.html" },
    { "source": "/my-evites", "destination": "/frontend/pages/my-evites.html" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 15
    }
  }
}
